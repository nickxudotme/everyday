---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryList from '../../components/EntryList.astro';
import { byDateDesc, isPublished } from '../../lib/content';

const notes = (await getCollection('notes')).filter(isPublished).sort(byDateDesc);
---

<BaseLayout title="Notes" description="短记录、碎片想法和日常观察。">
  <section class="page-intro">
    <p class="kicker">Notes</p>
    <h1>短记录，先接住念头。</h1>
    <p>这里不追求完整。一个问题、一段观察、一点工作后的余温，都可以先放在这里。</p>
  </section>
  <EntryList entries={notes} kind="notes" />
</BaseLayout>
