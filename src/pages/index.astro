---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EntryList from '../components/EntryList.astro';
import { byDateDesc, isPublished } from '../lib/content';

const notes = (await getCollection('notes')).filter(isPublished).sort(byDateDesc);
const latest = notes.slice(0, 8);
---

<BaseLayout title="everyday" description="NX 的日常短记录和碎碎念。">
  <section class="home-hero">
    <div>
      <p class="kicker">everyday.nickxu.me</p>
      <h1>把还没有想清楚的生活，也先写下来。</h1>
      <p>
        这里只放短的 notes：一些念头、观察、困惑和当天留下来的片段。
        如果某个问题慢慢长大，它以后会去 blog.nickxu.me。
      </p>
    </div>
    <aside class="today-panel" aria-label="Writing mode">
      <span>Today</span>
      <strong>{new Intl.DateTimeFormat('zh-CN', { month: 'long', day: 'numeric' }).format(new Date())}</strong>
      <p>一句话也算写作。先留下，再回头。</p>
    </aside>
  </section>

  <section class="split-section">
    <a class="mode-link notes-mode" href="/notes">
      <span>Notes</span>
      <strong>零散、及时、不必完整</strong>
      <small>{notes.length} entries</small>
    </a>
    <a class="mode-link blog-mode" href="https://blog.nickxu.me/">
      <span>Blog</span>
      <strong>想清楚之后，再认真写</strong>
      <small>coming next</small>
    </a>
  </section>

  <section class="content-section">
    <div class="section-heading">
      <p class="kicker">Latest</p>
      <h2>最近写下的东西</h2>
    </div>
    <EntryList entries={latest} />
  </section>
</BaseLayout>
