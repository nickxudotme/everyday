---
import { getCollection } from 'astro:content';
import WritingLayout from '../layouts/WritingLayout.astro';
import { byDateDesc, isPublic, isPublished } from '../lib/content';

export async function getStaticPaths() {
  const notes = (await getCollection('notes')).filter((entry) => isPublished(entry) && isPublic(entry)).sort(byDateDesc);

  return notes.map((entry, index) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      previousEntry: notes[index + 1],
      nextEntry: notes[index - 1]
    }
  }));
}

const { entry, previousEntry, nextEntry } = Astro.props;
---

<WritingLayout entry={entry} previousEntry={previousEntry} nextEntry={nextEntry} />
