---
import { formatDate, readingTime } from '../lib/content';
import type { Writing } from '../lib/content';

interface Props {
  entries: Writing[];
  kind?: 'notes' | 'essays';
}

const { entries, kind } = Astro.props;
---

<ol class:list={['entry-list', kind === 'notes' ? 'compact' : '']}>
  {
    entries.map((entry: Writing) => {
      const entryKind = kind ?? entry.collection;
      const extraMeta = entry.collection === 'notes' ? entry.data.mood : entry.data.series;

      return (
      <li>
        <a class="entry-title" href={`/${entryKind}/${entry.slug}/`}>
          {entry.data.title}
        </a>
        <div class="entry-meta">
          <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
          <span>{readingTime(entry.body)} min</span>
          {extraMeta && <span>{extraMeta}</span>}
        </div>
        {entry.data.summary && <p>{entry.data.summary}</p>}
        {
          entry.data.tags.length > 0 && (
            <div class="tags" aria-label="Tags">
              {entry.data.tags.map((tag: string) => (
                <span>{tag}</span>
              ))}
            </div>
          )
        }
      </li>
      );
    })
  }
</ol>
