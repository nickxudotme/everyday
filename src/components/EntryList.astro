---
import { formatDate, readingTime } from '../lib/content';
import type { Note } from '../lib/content';

interface Props {
  entries: Note[];
}

const { entries } = Astro.props;
---

<ol class="entry-list compact">
  {
    entries.map((entry: Note) => (
      <li>
        <a class="entry-title" href={`/${entry.slug}`}>
          {entry.data.title}
        </a>
        <div class="entry-meta">
          <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
          <span>{readingTime(entry.body)} min</span>
          {entry.data.mood && <span>{entry.data.mood}</span>}
        </div>
        {entry.data.summary && <p>{entry.data.summary}</p>}
        {
          entry.data.tags.length > 0 && (
            <div class="tags" aria-label="Tags">
              {entry.data.tags.map((tag: string) => (
                <span>{tag}</span>
              ))}
            </div>
          )
        }
      </li>
    ))
  }
</ol>
