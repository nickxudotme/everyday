---
import { formatDate, isPublic, readingTime } from '../lib/content';
import type { Note } from '../lib/content';

interface Props {
  entries: Note[];
  startIndex?: number;
}

const { entries, startIndex = 0 } = Astro.props;
---

<ol class="entry-list compact">
  {
    entries.map((entry: Note, index: number) => {
      const publicEntry = isPublic(entry);

      return (
        <li data-entry-index={startIndex + index}>
          {publicEntry ? (
            <a class="entry-title" href={`/${entry.slug}`}>
              {entry.data.title}
            </a>
          ) : (
            <span class="entry-title private-entry-title">{entry.data.title}</span>
          )}
          <div class="entry-meta">
            <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
            {publicEntry ? <span>{readingTime(entry.body)} min</span> : <span>不公开</span>}
            {publicEntry && entry.data.mood && <span>{entry.data.mood}</span>}
          </div>
          {publicEntry && entry.data.summary && <p>{entry.data.summary}</p>}
          {publicEntry && entry.data.tags.length > 0 && (
            <div class="tags" aria-label="Tags">
              {entry.data.tags.map((tag: string) => (
                <span>{tag}</span>
              ))}
            </div>
          )}
        </li>
      );
    })
  }
</ol>
