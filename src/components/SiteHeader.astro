---
const nav = [
  { href: '/', label: 'Everyday' },
  { href: '/notes', label: 'Notes' },
  { href: '/about', label: 'About' }
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header">
  <a class="brand" href="/" aria-label="Everyday home">
    <span class="brand-mark">NX</span>
    <span>everyday</span>
  </a>
  <div class="header-actions">
    <nav aria-label="Primary">
      {
        nav.map((item) => (
          <a class:list={[currentPath === item.href && 'active']} href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>
    <button class="theme-toggle" type="button" aria-label="Switch to dark mode" data-theme-toggle>
      <span class="theme-icon light" aria-hidden="true"></span>
      <span class="theme-icon dark" aria-hidden="true"></span>
    </button>
  </div>
</header>
