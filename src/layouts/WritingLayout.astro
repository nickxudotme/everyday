---
import BaseLayout from './BaseLayout.astro';
import { formatDate, readingTime } from '../lib/content';
import type { Note } from '../lib/content';

interface Props {
  entry: Note;
  previousEntry?: Note;
  nextEntry?: Note;
}

const { entry, previousEntry, nextEntry } = Astro.props;
const { Content } = await entry.render();
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <article class="writing-page notes">
    <a class="back-link" href="/#timeline">Back to notes</a>
    <header class="writing-header">
      <p class="kicker">Note</p>
      <h1>{entry.data.title}</h1>
      <div class="entry-meta">
        <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
        <span>{readingTime(entry.body)} min read</span>
        {entry.data.updated && <span>updated {formatDate(entry.data.updated)}</span>}
      </div>
      {entry.data.summary && <p class="summary">{entry.data.summary}</p>}
      {
        entry.data.tags.length > 0 && (
          <div class="tags" aria-label="Tags">
            {entry.data.tags.map((tag: string) => (
              <span>{tag}</span>
            ))}
          </div>
        )
      }
    </header>
    <div class="prose">
      <Content />
    </div>
    {(previousEntry || nextEntry) && (
      <nav class="note-pagination" aria-label="Adjacent notes">
        {previousEntry ? (
          <a href={`/${previousEntry.slug}`}>
            <span>上一篇</span>
            <strong>
              {previousEntry.data.title}
              <small>（{formatDate(previousEntry.data.date)}）</small>
            </strong>
          </a>
        ) : (
          <span />
        )}
        {nextEntry && (
          <a href={`/${nextEntry.slug}`}>
            <span>下一篇</span>
            <strong>
              {nextEntry.data.title}
              <small>（{formatDate(nextEntry.data.date)}）</small>
            </strong>
          </a>
        )}
      </nav>
    )}
    <a class="notes-return-link" href="/#timeline">回到时间线</a>
  </article>
  <script is:inline define:vars={{ previousHref: previousEntry ? `/${previousEntry.slug}` : '', nextHref: nextEntry ? `/${nextEntry.slug}` : '' }}>
    window.addEventListener('keydown', (event) => {
      const target = event.target;
      const isTyping =
        target instanceof HTMLElement &&
        (target.isContentEditable || ['INPUT', 'TEXTAREA', 'SELECT'].includes(target.tagName));

      if (isTyping || event.metaKey || event.ctrlKey || event.altKey) {
        return;
      }

      if (event.key === 'ArrowLeft' && previousHref) {
        window.location.href = previousHref;
      }

      if (event.key === 'ArrowRight' && nextHref) {
        window.location.href = nextHref;
      }
    });
  </script>
</BaseLayout>
